# ─────────────────────────────────────────────────────────
# Infrastructure Environment Variables
# ─────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control!
# ─────────────────────────────────────────────────────────

# VPS Access
VPS_HOST=your-vps-ip-or-domain
VPS_USER=root
VPS_SSH_KEY=~/.ssh/vps_deploy

# Existing Container Ports
# Update these to match your existing test/prod setup
TEST_PORT=3000
PROD_PORT=8080

# Optional: Email for Let's Encrypt notifications
# CADDY_EMAIL=your@email.com
