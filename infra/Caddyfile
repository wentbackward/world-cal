# ─────────────────────────────────────────────────────────
# Caddy Reverse Proxy Configuration
# ─────────────────────────────────────────────────────────
#
# Handles ALL subdomain traffic. Bare domain (paulgresham.com)
# and www stay on Hostinger managed hosting.
#
# Add new apps by adding a block below.
# ─────────────────────────────────────────────────────────

# ── Crisis Monitor ───────────────────────────────────────
# Existing containers, currently exposed on ports 3001/3002.
# Now routed through Caddy with automatic HTTPS.

crisis.paulgresham.com {
    reverse_proxy localhost:3002
}

crisis-test.paulgresham.com {
    reverse_proxy localhost:3001
}

# ── Subdomain Apps ───────────────────────────────────────
# Each app runs as its own container on the app-net network.
# Caddy discovers them by container name.

world-cal.paulgresham.com {
    reverse_proxy world-cal:80
}

# Add new apps here:
# another-app.paulgresham.com {
#     reverse_proxy another-app:80
# }
